{
  "manifest_version": 3,
  "name": "Chess.com Board Color Customizer",
  "version": "1.0",
  "description": "Customize your chess.com board with 3 premium, elegant color combinations.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.chess.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chess.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
